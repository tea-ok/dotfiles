" Repo-managed IdeaVim config for JetBrains IDEs.
" Apply with: ./apply.sh ideavim
"
" Notes:
" - This ports the overlapping "muscle memory" from the Neovim config.
" - Neovim-only features are mapped to the closest JetBrains actions.
" - To discover or verify action ids inside the IDE, use:
"   - :actionlist
"   - "IdeaVim: track action IDs" from Search Everywhere

let mapleader = " "
let maplocalleader = " "

nnoremap <Space> <Nop>
xnoremap <Space> <Nop>

" IdeaVim plugin emulation.
set surround
set commentary
set NERDTree

" Editor behavior close to the Neovim setup.
set number
set relativenumber
set scrolloff=4
set sidescrolloff=4
set incsearch
set hlsearch
set ignorecase
set smartcase
set wrap
set clipboard+=unnamedplus,ideaput

" IdeaVim-specific behavior.
set ideajoin
set idearefactormode=keep
set ideastatusicon=gray

" Core motions.
nnoremap Q <Nop>
nnoremap <Esc> :nohlsearch<CR>
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l
nnoremap <C-Up> <C-w>+
nnoremap <C-Down> <C-w>-
nnoremap <C-Left> <C-w><
nnoremap <C-Right> <C-w>>
nmap <C-o> <Action>(Back)
nmap <C-i> <Action>(Forward)

nnoremap H ^
nnoremap L $
xnoremap H ^
xnoremap L $
onoremap H ^
onoremap L $

" Visual editing behavior.
xnoremap p "_dP
xnoremap J :move '>+1<CR>gv=gv
xnoremap K :move '<-2<CR>gv=gv
xmap / gc

" Editor tabs approximate Neovim buffers.
nmap [b <Action>(PreviousTab)
nmap ]b <Action>(NextTab)
nmap <leader>x <Action>(CloseEditor)

" Search and navigation.
nmap <leader>ff <Action>(GotoFile)
nmap <leader>fh <Action>(GotoFile)
nmap <leader>fg <Action>(FindInPath)
nmap <leader>fb <Action>(Switcher)
nmap <leader>e <Action>(SelectInProjectView)

" IDE-powered code navigation.
nmap K <Action>(ShowHoverInfo)
nmap <leader>k <Action>(ShowErrorDescription)
nmap gd <Action>(GotoDeclaration)
nmap gD <Action>(GotoDeclaration)
nmap gi <Action>(GotoImplementation)
nmap go <Action>(GotoTypeDeclaration)
nmap gr <Action>(ShowUsages)
nmap gs <Action>(ParameterInfo)
nmap <leader>rn <Action>(RenameElement)
nmap <leader>ca <Action>(ShowIntentionActions)
nmap <leader>fm <Action>(ReformatCode)
nmap <leader>ra <Action>(ShowIntentionActions)

" Useful JetBrains-native extras that fit the current workflow.
nmap <leader>tt <Action>(ActivateTerminalToolWindow)
nmap <leader>o <Action>(FileStructurePopup)

" Not ported directly:
" - Snacks terminals, lazygit, and auto-session
" - Telescope split-opening variants
" - Neovide-only clipboard mappings
