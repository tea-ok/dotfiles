#!/usr/bin/env bash
set -euo pipefail

have() { command -v "$1" &>/dev/null; }
os_is_atomic() { have rpm-ostree; }

# ── Create local secrets file if missing ─────────────────────────────────────
local_zsh="${HOME}/.config/zsh/local.zsh"
if [[ ! -f "$local_zsh" ]]; then
  mkdir -p "$(dirname "$local_zsh")"
  cat > "$local_zsh" <<'LOCALEOF'
# ~/.config/zsh/local.zsh
# Machine-local configuration — not tracked in version control.
# Add secrets, API keys, tokens, and machine-specific settings here.

# export OPENAI_API_KEY=""
# export ANTHROPIC_API_KEY=""
# export GITHUB_TOKEN=""
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
# export AWS_DEFAULT_REGION=""
LOCALEOF
  echo "[final] Created $local_zsh — fill in your secrets there."
else
  echo "[final] $local_zsh already exists. Skipping."
fi

cat <<'EOF'

╔══════════════════════════════════════════════════════════════════╗
║               Bootstrap complete — next steps                   ║
╚══════════════════════════════════════════════════════════════════╝

1. Refresh your shell
   Open a new terminal window or log out and log back in.
   Your default shell may have changed to zsh — it takes effect on
   the next login.

2. Add your secrets
   Fill in API keys and tokens in:  ~/.config/zsh/local.zsh
   This file is not tracked by chezmoi or git.

3. Install tmux plugins
   Start tmux, then press:  prefix + I  (capital i)
   TPM will install all plugins listed in ~/.tmux.conf.

EOF

if os_is_atomic; then
  cat <<'EOF'
4. Reboot (atomic Linux)
   This system uses rpm-ostree. If any packages were installed or
   updated, a reboot is required before they take effect:

     sudo systemctl reboot

EOF
fi

cat <<'EOF'
5. Alacritty desktop icon (Linux only)
   If you see a blank or missing icon for Alacritty in your app
   launcher, edit the desktop entry and set the correct icon path:

     ~/.local/share/applications/alacritty.desktop

   Set the Icon= field to the .svg bundled with Alacritty, e.g.:
     Icon=~/.cargo/registry/src/<hash>/alacritty-<ver>/extra/logo/alacritty-term.svg

EOF
