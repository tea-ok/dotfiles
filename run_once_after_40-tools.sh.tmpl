#!/usr/bin/env bash
set -euo pipefail

# ── helpers ──────────────────────────────────────────────────────────────────
log()  { echo "[tools] $*"; }
warn() { echo "[tools] WARNING: $*" >&2; }

have() { command -v "$1" &>/dev/null; }

os_is_mac() { [[ "$(uname -s)" == Darwin ]]; }

eval_brew_shellenv() {
  local brew_bin
  if os_is_mac; then
    brew_bin="/opt/homebrew/bin/brew"
    [[ -x "$brew_bin" ]] || brew_bin="/usr/local/bin/brew"
  else
    brew_bin="/home/linuxbrew/.linuxbrew/bin/brew"
    [[ -x "$brew_bin" ]] || brew_bin="$HOME/.linuxbrew/bin/brew"
  fi
  if [[ -x "$brew_bin" ]]; then eval "$("$brew_bin" shellenv)"; fi
}

brew_install_if_missing() {
  local pkg="$1"
  if brew list --formula "$pkg" &>/dev/null || brew list --cask "$pkg" &>/dev/null; then
    log "$pkg already installed via Homebrew. Skipping."
  elif have "$pkg"; then
    log "$pkg already on PATH. Skipping."
  else
    log "Installing $pkg..."
    brew install "$pkg" || warn "brew install $pkg failed — install manually if needed."
  fi
}

# ── Load brew shellenv ────────────────────────────────────────────────────────
eval_brew_shellenv

if ! have brew; then
  warn "brew not found. Cannot install tools. Re-run after Homebrew is installed."
  exit 1
fi

# ── Install tools ─────────────────────────────────────────────────────────────
for tool in chezmoi tmux neovim fastfetch gh lazygit ripgrep markdownlint-cli2 unzip; do
  brew_install_if_missing "$tool"
done

log "Done. Note: gh auth login was intentionally not run — the dotfiles repo is public."
