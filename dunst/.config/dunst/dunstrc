# Catppuccin Frappe colors adapted from catppuccin/dunst at commit
# 5955cf0213d14a3494ec63580a81818b6f7caa66.

[global]
    monitor = 0
    follow = keyboard

    width = 360
    height = (0, 160)
    origin = top-right
    offset = (20, 20)
    scale = 0
    notification_limit = 8

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 120
    progress_bar_max_width = 280
    progress_bar_corner_radius = 4
    progress_bar_corners = all

    icon_corner_radius = 8
    icon_corners = all
    indicate_hidden = yes
    transparency = 0
    separator_height = 0
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    frame_width = 2
    gap_size = 8
    separator_color = frame

    font = JetBrainsMono Nerd Font 11
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    sticky_history = yes
    history_length = 20

    dmenu = /usr/bin/rofi -dmenu -p dunst:
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst

    corner_radius = 10
    corners = all
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false
    pause_on_mouse_over = true
    enable_pcre_regex = false

[urgency_low]
    background = "#303446"
    foreground = "#c6d0f5"
    frame_color = "#8caaee"
    highlight = "#8caaee"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#303446"
    foreground = "#c6d0f5"
    frame_color = "#8caaee"
    highlight = "#8caaee"
    timeout = 8
    override_pause_level = 30
    default_icon = dialog-information

[urgency_critical]
    background = "#303446"
    foreground = "#c6d0f5"
    frame_color = "#ef9f76"
    highlight = "#8caaee"
    timeout = 0
    override_pause_level = 60
    default_icon = dialog-warning
