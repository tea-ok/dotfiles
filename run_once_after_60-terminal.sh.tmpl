#!/usr/bin/env bash
set -euo pipefail

# ── helpers ──────────────────────────────────────────────────────────────────
log()  { echo "[terminal] $*"; }
warn() { echo "[terminal] WARNING: $*" >&2; }

have() { command -v "$1" &>/dev/null; }

os_is_mac()    { [[ "$(uname -s)" == Darwin ]]; }
os_is_ubuntu() { [[ -f /etc/os-release ]] && grep -qi 'ID=ubuntu' /etc/os-release; }

eval_brew_shellenv() {
  local brew_bin
  if os_is_mac; then
    brew_bin="/opt/homebrew/bin/brew"
    [[ -x "$brew_bin" ]] || brew_bin="/usr/local/bin/brew"
  else
    brew_bin="/home/linuxbrew/.linuxbrew/bin/brew"
    [[ -x "$brew_bin" ]] || brew_bin="$HOME/.linuxbrew/bin/brew"
  fi
  if [[ -x "$brew_bin" ]]; then eval "$("$brew_bin" shellenv)"; fi
}

load_cargo_env() {
  if [[ -f "$HOME/.cargo/env" ]]; then source "$HOME/.cargo/env"; fi
}

# ── Env flags ─────────────────────────────────────────────────────────────────
INSTALL_GUI_TERMINAL="${INSTALL_GUI_TERMINAL:-auto}"
INSTALL_ALACRITTY_DESKTOP="${INSTALL_ALACRITTY_DESKTOP:-yes}"

eval_brew_shellenv
load_cargo_env

# ── GUI detection ─────────────────────────────────────────────────────────────
is_gui() {
  if [[ "$INSTALL_GUI_TERMINAL" == "yes" ]]; then return 0; fi
  if [[ "$INSTALL_GUI_TERMINAL" == "no" ]];  then return 1; fi
  # auto: headless if SSH, GUI if DISPLAY/WAYLAND_DISPLAY set
  if [[ -n "${SSH_CONNECTION:-}" || -n "${SSH_CLIENT:-}" || -n "${SSH_TTY:-}" ]]; then
    return 1
  fi
  if [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ]]; then
    return 0
  fi
  return 1
}

# ── macOS ─────────────────────────────────────────────────────────────────────
if os_is_mac; then
  if ! is_gui; then
    log "INSTALL_GUI_TERMINAL=no — skipping Ghostty install."
    exit 0
  fi

  if ! have brew; then
    warn "brew not found — cannot install Ghostty."
    exit 0
  fi

  if brew list --cask ghostty &>/dev/null; then
    log "Ghostty already installed. Skipping."
  else
    log "Installing Ghostty via Homebrew cask..."
    brew install --cask ghostty || warn "brew install ghostty failed — install manually if needed."
  fi

  log "Done."
  exit 0
fi

# ── Linux ─────────────────────────────────────────────────────────────────────
if ! is_gui; then
  log "Headless Linux detected (no DISPLAY/WAYLAND_DISPLAY or SSH session). Skipping terminal emulator install."
  exit 0
fi

# ── Install Alacritty via cargo ───────────────────────────────────────────────
if have alacritty; then
  log "Alacritty already on PATH at $(command -v alacritty). Skipping build."
else
  # Install build deps only when we actually need to build
  if os_is_ubuntu; then
    log "Installing Alacritty build dependencies via apt..."
    sudo apt-get install -y \
      cmake \
      pkg-config \
      libfreetype6-dev \
      libfontconfig1-dev \
      libxcb-xfixes0-dev \
      libxkbcommon-dev \
      python3 \
      desktop-file-utils || warn "Some apt deps may have failed — Alacritty build might fail."
  fi
  if ! have cargo; then
    warn "cargo not found — cannot build Alacritty. Install Rust first."
    exit 0
  fi
  log "Installing Alacritty via cargo..."
  cargo install alacritty || {
    warn "cargo install alacritty failed — install manually if needed."
    exit 0
  }
fi

# ── Alacritty desktop entry ───────────────────────────────────────────────────
if [[ "$INSTALL_ALACRITTY_DESKTOP" != "yes" ]]; then
  log "INSTALL_ALACRITTY_DESKTOP=${INSTALL_ALACRITTY_DESKTOP} — skipping desktop entry."
  exit 0
fi

if ! have alacritty; then
  warn "alacritty not on PATH — skipping .desktop file creation."
  exit 0
fi

DESKTOP_DIR="$HOME/.local/share/applications"
mkdir -p "$DESKTOP_DIR"

DESKTOP_FILE="$DESKTOP_DIR/alacritty.desktop"

if [[ -f "$DESKTOP_FILE" ]]; then
  log "Desktop entry already exists at $DESKTOP_FILE. Skipping (preserving any manual edits)."
  exit 0
fi

# Auto-detect icon path
ICON_PATH=""
for candidate in \
  "$HOME/.cargo/registry/src"/*/alacritty-*/extra/logo/alacritty-term.svg \
  "$HOME/.cargo/registry/src"/*/alacritty-*/extra/logo/alacritty.svg \
  /usr/share/pixmaps/Alacritty.svg \
  /usr/share/pixmaps/alacritty.svg \
  /usr/share/icons/hicolor/scalable/apps/Alacritty.svg \
  /usr/share/icons/hicolor/scalable/apps/alacritty.svg; do
  # Use glob expansion result (first match)
  for expanded in $candidate; do
    if [[ -f "$expanded" ]]; then
      ICON_PATH="$expanded"
      break 2
    fi
  done
done

if [[ -n "$ICON_PATH" ]]; then
  log "Found Alacritty icon at: $ICON_PATH"
else
  warn "Could not auto-detect Alacritty icon path."
  warn "The .desktop file will be created with an empty Icon= field."
  warn "Edit $DESKTOP_FILE and set the correct Icon= path manually."
fi

log "Writing $DESKTOP_FILE..."
cat > "$DESKTOP_FILE" <<EOF
[Desktop Entry]
Type=Application
Name=Alacritty
Exec=alacritty
Icon=${ICON_PATH}
Terminal=false
Categories=System;TerminalEmulator;
StartupWMClass=Alacritty
EOF

if have update-desktop-database; then
  update-desktop-database "$DESKTOP_DIR" 2>/dev/null || \
    warn "update-desktop-database failed — desktop entry may not be immediately visible."
fi

log "Desktop entry created at $DESKTOP_FILE"
log "Done."
